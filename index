let currentTab = 'all';
let currentFilter = 'all';
let searchQuery = '';
let expandedId = null;

function getStatusClass(status) {
  if (status.includes('URGENT')) return 'status-urgent';
  if (status.includes('IMMEDIATE')) return 'status-immediate';
  if (status.includes('OPEN')) return 'status-open';
  if (status.includes('MONITOR')) return 'status-monitor';
  if (status.includes('LONG')) return 'status-long';
  if (status.includes('LOW')) return 'status-low';
  return 'status-monitor';
}

function getScoreClass(score) {
  if (score >= 4.0) return 'score-high';
  if (score >= 3.0) return 'score-mid';
  return 'score-low';
}

function getFilteredData() {
  let data = opportunities;

  // Tab filtering
  if (currentTab === 'top50') data = data.slice(0, 50);
  else if (currentTab === 'top25') data = data.slice(0, 25);
  else if (currentTab === 'immediate') {
    data = data.filter(o => o["Status Tracker"].includes('IMMEDIATE') || o["Status Tracker"].includes('URGENT') || o.Rank <= 15);
  }

  // Status filter
  if (currentFilter === 'open') data = data.filter(o => o["Status Tracker"].includes('OPEN'));
  else if (currentFilter === 'urgent') data = data.filter(o => o["Status Tracker"].includes('URGENT'));
  else if (currentFilter === 'immediate') data = data.filter(o => o["Status Tracker"].includes('IMMEDIATE'));
  else if (currentFilter === 'sa') data = data.filter(o => o.Country.includes('South Africa'));
  else if (currentFilter === 'panafrican') data = data.filter(o => o.Country.includes('Africa') && !o.Country.includes('South Africa'));
  else if (currentFilter === 'nondilutive') data = data.filter(o => o["Non-dilutive or Dilutive"] === 'Non-Dilutive');

  // Search
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    data = data.filter(o => 
      (o.Organisation && o.Organisation.toLowerCase().includes(q)) ||
      (o.Programme && o.Programme.toLowerCase().includes(q)) ||
      (o.Country && o.Country.toLowerCase().includes(q)) ||
      (o.Category && o.Category.toLowerCase().includes(q)) ||
      (o["Funding Type"] && o["Funding Type"].toLowerCase().includes(q))
    );
  }

  return data;
}

function renderTable() {
  if (currentTab === 'roadmap') {
    renderRoadmap();
    return;
  }

  const data = getFilteredData();
  const content = document.getElementById('content');

  if (data.length === 0) {
    content.innerHTML = '<div class="empty-state">No opportunities match your filters. Try adjusting your search or filters.</div>';
    return;
  }

  let html = '<div class="table-container"><div class="table-header"><div>Rank</div><div>Organisation / Programme</div><div>Amount</div><div>Country</div><div>Status</div><div>Score</div></div>';

  data.forEach(opp => {
    const id = opp.Rank;
    const isExpanded = expandedId === id;

    html += `<div class="opp-row" onclick="toggleDetail(${id})">`;
    html += `<div class="opp-rank">${opp.Rank}</div>`;
    html += `<div><div class="opp-name">${opp.Programme}</div><div class="opp-org">${opp.Organisation}</div></div>`;
    html += `<div class="opp-amount">${opp["Amount Available"]}</div>`;
    html += `<div class="opp-country">${opp.Country}</div>`;
    html += `<div class="opp-status"><span class="status-pill ${getStatusClass(opp["Status Tracker"])}">${opp["Status Tracker"].replace('OPEN - ', '')}</span></div>`;
    html += `<div class="opp-score ${getScoreClass(opp["Overall Priority Score"])}">${opp["Overall Priority Score"]}</div>`;
    html += `</div>`;

    // Detail panel
    html += `<div class="detail-panel ${isExpanded ? 'active' : ''}" id="detail-${id}">`;
    html += `<div class="detail-header">${opp.Organisation} — ${opp.Programme}</div>`;
    html += `<div class="detail-grid">`;
    html += `<div class="detail-item"><div class="detail-label">Category</div><div class="detail-value">${opp.Category}</div></div>`;
    html += `<div class="detail-item"><div class="detail-label">Funding Type</div><div class="detail-value">${opp["Funding Type"]}</div></div>`;
    html += `<div class="detail-item"><div class="detail-label">Non-Dilutive / Dilutive</div><div class="detail-value">${opp["Non-dilutive or Dilutive"]}</div></div>`;
    html += `<div class="detail-item"><div class="detail-label">Application Window</div><div class="detail-value">${opp["Application Window"]}</div></div>`;
    html += `<div class="detail-item"><div class="detail-label">Strategic Fit</div><div class="detail-value">${opp["Strategic Fit Score (1-5)"]}/5 · Probability: ${opp["Probability of Success (1-5)"]}/5 · Speed: ${opp["Speed to Funding (1-5)"]}/5 · Effort: ${opp["Effort Required (1-5)"]}/5</div></div>`;
    html += `<div class="detail-item"><div class="detail-label">Overall Score</div><div class="detail-value" style="font-weight:800;color:var(--accent);">${opp["Overall Priority Score"]}</div></div>`;
    html += `<div class="detail-item"><div class="detail-label">Website</div><div class="detail-value"><a href="${opp.Website}" target="_blank">${opp.Website}</a></div></div>`;
    html += `<div class="detail-item"><div class="detail-label">Application URL</div><div class="detail-value"><a href="${opp["Application URL"]}" target="_blank">${opp["Application URL"]}</a></div></div>`;
    html += `<div class="detail-item"><div class="detail-label">Contact Person</div><div class="detail-value">${opp["Contact Person"]}</div></div>`;
    html += `<div class="detail-item"><div class="detail-label">Contact Email</div><div class="detail-value"><a href="mailto:${opp["Contact Email"]}">${opp["Contact Email"]}</a></div></div>`;
    html += `<div class="detail-item detail-full"><div class="detail-label">Documents Required</div><div class="detail-value">${opp["Documents Required"]}</div></div>`;
    html += `<div class="detail-item detail-full"><div class="detail-label">Next Action</div><div class="detail-value" style="font-weight:600;">${opp["Next Action"]}</div></div>`;
    html += `</div>`;
    html += `<div class="detail-notes"><strong>Eligibility for ImpiraTech:</strong> ${opp["Eligibility Notes for ImpiraTech"]}</div>`;
    html += `<div class="detail-actions">`;
    html += `<a class="btn btn-primary" href="${opp["Application URL"]}" target="_blank">Open Application →</a>`;
    html += `<a class="btn btn-secondary" href="${opp.Website}" target="_blank">Visit Website</a>`;
    html += `<a class="btn btn-secondary" href="mailto:${opp["Contact Email"]}?subject=ImpiraTech - ${opp.Programme} Application Inquiry">Email Contact</a>`;
    html += `</div>`;
    html += `</div>`;
  });

  html += `</div><div style="text-align:center;padding:16px;font-size:12px;color:var(--text-tertiary);">Showing ${data.length} of ${opportunities.length} opportunities</div>`;
  content.innerHTML = html;
}

function renderRoadmap() {
  const content = document.getElementById('content');
  let html = '<div class="roadmap-container">';

  roadmap.forEach(phase => {
    html += `<div class="phase-section"><div class="phase-title" style="border-color:${phase.color};color:${phase.color}">${phase.phase}</div>`;
    phase.items.forEach(item => {
      html += `<div class="roadmap-item">`;
      html += `<div class="roadmap-num" style="background:${phase.color}">${item.num}</div>`;
      html += `<div class="roadmap-content">`;
      html += `<div class="roadmap-action">${item.action}</div>`;
      html += `<div class="roadmap-meta">${item.opp} · ${item.owner} · ${item.time} · ${item.cost}</div>`;
      html += `<div class="roadmap-impact">Impact: ${item.impact}</div>`;
      if (item.deps && item.deps !== 'None') {
        html += `<div class="roadmap-meta" style="margin-top:4px;color:var(--warning)">Dependencies: ${item.deps}</div>`;
      }
      html += `</div></div>`;
    });
    html += `</div>`;
  });

  html += `</div>`;
  content.innerHTML = html;
}

function toggleDetail(id) {
  if (expandedId === id) {
    expandedId = null;
  } else {
    expandedId = id;
  }
  renderTable();
  if (expandedId === id) {
    setTimeout(() => {
      const el = document.getElementById(`detail-${id}`);
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 100);
  }
}

function switchTab(tab) {
  currentTab = tab;
  expandedId = null;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`[data-tab="${tab}"]`).classList.add('active');

  const filters = document.getElementById('filters');
  if (tab === 'roadmap') {
    filters.style.display = 'none';
  } else {
    filters.style.display = 'flex';
  }

  renderTable();
}

function setFilter(filter) {
  currentFilter = filter;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  document.querySelector(`[data-filter="${filter}"]`).classList.add('active');
  renderTable();
}

function handleSearch() {
  searchQuery = document.getElementById('searchInput').value;
  renderTable();
}

// Initial render
renderTable();
</script>
